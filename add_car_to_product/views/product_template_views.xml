<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="test_task_product_template_product_form_autoparts" model="ir.ui.view">
        <field name="name">test.task.product.template.product.form.autoparts</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='group_general']/field[@name='create_repair']" position="after">
                <field name="is_autoparts"/>
            </xpath>
        </field>
    </record>
</odoo>
